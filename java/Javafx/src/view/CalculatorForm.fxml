         <font>
            <Font size="21.0" />
         </font>
      </Label>
      <TextField fx:id="txtNum1" layoutX="80.0" layoutY="48.0" prefHeight="41.0" prefWidth="85.0" promptText="1st number" />
      <TextField fx:id="txtNum2" layoutX="199.0" layoutY="48.0" onAction="#txtNumOnAction" prefHeight="41.0" prefWidth="85.0" promptText="2nd number" />
      <Label layoutX="172.0" layoutY="43.0" prefHeight="55.0" prefWidth="27.0" style="-fx-background-color: #ffffff;" text="+">
