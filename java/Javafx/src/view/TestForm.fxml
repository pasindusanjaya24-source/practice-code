<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TestFormController">
   <children>
      <TextField fx:id="txtSomething" layoutX="31.0" layoutY="109.0" onAction="#txtSomethingOnAction" prefHeight="25.0" prefWidth="367.0" promptText="type something" />
      <Label layoutX="215.0" layoutY="-9.0" prefHeight="45.0" prefWidth="170.0" text=" Test Form" textAlignment="CENTER" textFill="#c70f0f" underline="true">
         <font>
            <Font name="Arial Bold" size="26.0" />
         </font>
      </Label>
      <Button layoutX="237.0" layoutY="44.0" mnemonicParsing="false" onAction="#btnClickMeOnAction" prefHeight="35.0" prefWidth="85.0" style="-fx-background-color: #34495e;" text="CliclkMe" textFill="#fdeded">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Button layoutX="433.0" layoutY="109.0" mnemonicParsing="false" onAction="#btnOKOnAction" prefHeight="25.0" prefWidth="53.0" style="-fx-background-color: orange;" text="OK">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Label fx:id="lblBanner" layoutX="176.0" layoutY="134.0" prefHeight="35.0" prefWidth="170.0" style="-fx-background-color: #ffffff;" />
      <Button layoutX="427.0" layoutY="187.0" mnemonicParsing="false" onAction="#btnSubmitOnAction" style="-fx-background-color: yellow;" text="Submit">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <TextField fx:id="txtName" layoutX="79.0" layoutY="187.0" onAction="#txtNameOnAction" prefHeight="25.0" prefWidth="295.0" promptText="Eneter Your Name " />
      <Label layoutX="19.0" layoutY="181.0" prefHeight="35.0" prefWidth="60.0" style="-fx-background-color: #ffffff;" text="Name:" textAlignment="CENTER">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
