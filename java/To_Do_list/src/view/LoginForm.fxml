      </Button>
      <Button layoutX="98.0" layoutY="327.0" mnemonicParsing="false" onAction="#btnCreateOnAction" prefHeight="25.0" prefWidth="132.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8px;" text="Create New Account" textFill="#130bfd" underline="true">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Label layoutX="105.0" layoutY="417.0" prefHeight="19.0" prefWidth="176.0" style="-fx-background-color: #ffffff;" text="Designed By @psvide">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
