<AnchorPane fx:id="root" prefHeight="451.0" prefWidth="338.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginFormController">
   <children>
      <Label layoutX="83.0" layoutY="14.0" prefHeight="34.0" prefWidth="198.0" style="-fx-background-color: #ffffff;" text="Login To Do List">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <Label layoutX="36.0" layoutY="95.0" prefHeight="34.0" prefWidth="102.0" style="-fx-background-color: #ffffff;" text="User Name :">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <Label layoutX="32.0" layoutY="162.0" prefHeight="34.0" prefWidth="102.0" style="-fx-background-color: #ffffff;" text="Password :">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtUserName" layoutX="36.0" layoutY="136.0" prefHeight="25.0" prefWidth="243.0" style="-fx-background-radius: 6px;" />
      <PasswordField fx:id="txtPassword" layoutX="38.0" layoutY="201.0" onAction="#txtPasswordOnAction" prefHeight="25.0" prefWidth="243.0" style="-fx-background-radius: 2px;" />
      <Button layoutX="98.0" layoutY="271.0" mnemonicParsing="false" onAction="#btnLoginOnAction" prefHeight="25.0" prefWidth="132.0" style="-fx-background-color: blue; -fx-background-radius: 8px;" text="Login" textFill="#f4efef">
