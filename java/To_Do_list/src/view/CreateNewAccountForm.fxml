<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="485.0" prefWidth="335.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CreateNewAccountFormController">
   <children>
      <Label layoutX="65.0" layoutY="14.0" prefHeight="34.0" prefWidth="243.0" style="-fx-background-color: #ffffff;" text="Create New Account">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <Label layoutX="28.0" layoutY="108.0" prefHeight="34.0" prefWidth="102.0" style="-fx-background-color: #ffffff;" text="User Name :">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtUserName" layoutX="36.0" layoutY="142.0" prefHeight="25.0" prefWidth="243.0" style="-fx-background-radius: 6px;" />
      <Label layoutX="28.0" layoutY="174.0" prefHeight="34.0" prefWidth="102.0" style="-fx-background-color: #ffffff;" text="Email :">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtEmail" layoutX="36.0" layoutY="208.0" prefHeight="25.0" prefWidth="243.0" style="-fx-background-radius: 6px;" />
      <PasswordField fx:id="txtNewPassword" layoutX="36.0" layoutY="267.0" prefHeight="25.0" prefWidth="243.0" style="-fx-background-radius: 2px;" />
      <PasswordField fx:id="txtConfirmPassword" layoutX="36.0" layoutY="335.0" onAction="#txtConfirmPasswordOnAction" prefHeight="25.0" prefWidth="243.0" style="-fx-background-radius: 2px;" />
      <Label layoutX="28.0" layoutY="233.0" prefHeight="34.0" prefWidth="170.0" style="-fx-background-color: #ffffff;" text="New Password :">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <Label layoutX="28.0" layoutY="301.0" prefHeight="34.0" prefWidth="158.0" style="-fx-background-color: #ffffff;" text="Conform Password :">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <Button fx:id="btnRegister" layoutX="89.0" layoutY="385.0" mnemonicParsing="false" onAction="#btnRegisterOnAction" prefHeight="40.0" prefWidth="158.0" style="-fx-background-color: green; -fx-background-radius: 7px;" text="Register" textFill="#fbf6f6">
         <font>
            <Font size="19.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
      <Label layoutX="88.0" layoutY="458.0" prefHeight="19.0" prefWidth="176.0" style="-fx-background-color: #ffffff;" text="Designed By @psvide">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label fx:id="lblpassworddosenotmatched" layoutX="149.0" layoutY="360.0" prefHeight="17.0" prefWidth="158.0" style="-fx-background-color: #ffffff;" text="password doesn't matched" textFill="#ef2c2c" />
      <Label fx:id="lblID" layoutX="238.0" layoutY="99.0" text="userid " />
      <Button fx:id="btnAddUser" layoutX="193.0" layoutY="48.0" mnemonicParsing="false" onAction="#btnAddUserOnAction" prefHeight="40.0" prefWidth="124.0" style="-fx-background-color: blue; -fx-background-radius: 7px;" text="+ add user" textFill="#fbf6f6">
         <font>
            <Font size="19.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
   </children>
</AnchorPane>
